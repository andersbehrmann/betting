# --- Databas (Neon Postgres) ---
# Pooled connection string från Neon-projektet (Dashboard -> Connect -> Pooled connection).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Admin ---
# Lösenord för adminsidan (/admin). Välj något långt och unikt.
ADMIN_PASSWORD="byt-mig-till-nagot-hemligt"

# Hemlighet för att signera admin-sessionscookien. Generera t.ex. med:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="byt-mig-till-en-lang-slumpstrang"

# --- App ---
# Publik bas-URL (används för delningslänkar). Lokalt: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
