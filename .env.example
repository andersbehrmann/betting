# --- Databas (Neon Postgres) ---
# Pooled connection string från Neon-projektet (Dashboard -> Connect -> Pooled connection).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# --- App ---
# Publik bas-URL (delningslänkar, e-postlänkar). Lokalt: http://127.0.0.1:3007
# (Använd 127.0.0.1 istället för localhost för en egen, ren cookie-burk – slipper HTTP 431.)
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3007"

# --- Konton / admin ---
# Admin är en vanlig användare med is_admin=true. Skapa/uppgradera den med:
#   npm run bootstrap-admin -- --email ab@annors.se --name "Anders" --username anders --password "hemligt"
# (Lösenord hashas med scrypt; sessions lagras i DB. Inget delat adminlösenord längre.)

# --- E-post (Resend, för lösenordsåterställning) ---
# Utan RESEND_API_KEY loggas länken i terminalen istället (dev-fallback).
RESEND_API_KEY=""
RESEND_FROM="Tipskvällen <onboarding@resend.dev>"
